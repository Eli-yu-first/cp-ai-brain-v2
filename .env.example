# ============================================================================
# CP-AI Brain V2 Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# ============================================================================

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=mysql://user:password@localhost:3306/cpbrain

# ============================================================================
# Manus Platform Integration (Optional - for Manus OAuth)
# ============================================================================
# If not configured, the system will use local authentication

# OAuth Portal URL (e.g., https://oauth.manus.im)
VITE_OAUTH_PORTAL_URL=

# Application ID from Manus
VITE_APP_ID=

# Frontend Forge API Configuration
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=https://api.manus.ai

# Backend Forge API Configuration (auto-injected by Manus)
BUILT_IN_FORGE_API_KEY=
BUILT_IN_FORGE_API_URL=https://api.manus.ai

# JWT Secret for token signing
JWT_SECRET=

# OAuth Server URL
OAUTH_SERVER_URL=

# ============================================================================
# OpenAI Integration (Optional - fallback AI provider)
# ============================================================================
# If configured, the system will use OpenAI instead of Manus Forge API

OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1

# ============================================================================
# Local Authentication Configuration
# ============================================================================
# Used when Manus OAuth is not configured

LOCAL_ADMIN_PASSWORD=cpbrain2024

# ============================================================================
# Application Configuration
# ============================================================================
NODE_ENV=development
PORT=3000

# Application Title and Logo
VITE_APP_TITLE=CP-AI Brain V2
VITE_APP_LOGO=

# Analytics (auto-injected by Manus)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ============================================================================
# Advanced Configuration
# ============================================================================

# Session Configuration
SESSION_SECRET=your-session-secret
SESSION_TIMEOUT_MS=86400000

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Log Level (debug, info, warn, error)
LOG_LEVEL=info

# ============================================================================
# Notes
# ============================================================================
# 1. DATABASE_URL is required for database operations
# 2. For Manus deployment, most variables are auto-injected
# 3. For local development, use local authentication (no OAuth needed)
# 4. For AI features, either configure Manus or OpenAI keys
# 5. Keep JWT_SECRET and LOCAL_ADMIN_PASSWORD secure in production
